# --- Database (HANDOFF D2) ---
DATABASE_URL="postgresql://workhub:workhub@localhost:5432/workhub?schema=public"

# --- Auth.js (HANDOFF D3) — generate with: openssl rand -base64 32 ---
AUTH_SECRET="change-me-in-production"
AUTH_TRUST_HOST="true"

# --- Redis / BullMQ (HANDOFF D10, used from M2) ---
REDIS_URL="redis://localhost:6379"

# --- Object storage, S3-compatible (HANDOFF D11, used from M1 attachments) ---
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="workhub"
S3_SECRET_KEY="workhub-secret"
S3_BUCKET="workhub"

# --- External search, Elasticsearch/OpenSearch-compatible (optional) ---
# Leave WORKHUB_SEARCH_BACKEND unset or "postgres" to use bounded local search.
# Set WORKHUB_SEARCH_BACKEND="elasticsearch" or "opensearch" plus URL/index to query an external cluster.
WORKHUB_SEARCH_BACKEND="postgres"
WORKHUB_SEARCH_URL="http://localhost:9200"
WORKHUB_SEARCH_INDEX="workhub_search"
# WORKHUB_SEARCH_API_KEY=""
# WORKHUB_SEARCH_USERNAME=""
# WORKHUB_SEARCH_PASSWORD=""
WORKHUB_SEARCH_TIMEOUT_MS="5000"
